# Copy this file to .env and fill in real values
# Never commit .env to version control

# Database
POSTGRES_USER=workflow
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=workflow_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App
APP_ENV=development
FIRST_SUPERADMIN_EMAIL=admin@example.com
FIRST_SUPERADMIN_PASSWORD=change_me_admin_password

# System settings encryption key (generate: openssl rand -hex 32)
# If unset, a runtime-only key is generated (secrets lost on restart)
SETTINGS_ENCRYPT_KEY=change_me_generate_with_openssl_rand_hex_32
